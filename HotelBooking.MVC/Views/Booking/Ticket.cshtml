@model HotelBooking.MVC.Models.Booking

<h2 class="mb-4 text-success">🎫 Booking Confirmed</h2>

@if (Model != null)
{
    <div class="card shadow-sm p-4">
        <h5 class="text-primary mb-3">Booking Details</h5>

        <p><b>Booking ID:</b> @Model.BookingId</p>
        <p><b>Room Type:</b> @Model.RoomType</p>
        <p><b>Total Price:</b> ₹@Model.TotalPrice</p>
        <p><b>Status:Booked</b> 
        

        <div class="mt-3">
            <a asp-action="History" class="btn btn-outline-success w-100">View Booking History</a>
        </div>
    </div>
}